# Whop Configuration
# Get these from your Whop dashboard: https://whop.com/apps
WHOP_WEBHOOK_SECRET="get_this_after_creating_a_webhook_in_the_app_settings_screen"
WHOP_API_KEY=your_whop_api_key_here
NEXT_PUBLIC_WHOP_APP_ID=app_your_app_id_here
NEXT_PUBLIC_WHOP_COMPANY_ID=biz_your_company_id_here

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com

# Public keys (exposed to browser - safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only keys (NEVER expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Postgres Connection (optional - for direct DB access)
POSTGRES_URL=postgres://postgres.your-project:password@aws-region.pooler.supabase.com:6543/postgres
POSTGRES_PRISMA_URL=postgres://postgres.your-project:password@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project:password@aws-region.pooler.supabase.com:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.your-project.supabase.co
